# ============================================================
# Netlify Environment Variables
# Set these in your Netlify Dashboard → Site Settings → Environment Variables
# ============================================================

# --- Supabase ---
# Get these from your Supabase project dashboard → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# --- Gemini AI ---
# Get this from https://aistudio.google.com/app/apikey
# NEVER put this in frontend code — it lives in Netlify Functions only
GEMINI_API_KEY=your_gemini_api_key_here

# --- Submission Moderation ---
# Set to "true" to keep new submissions in "pending" status until manual approval.
# Leave as "false" to auto-approve all submissions.
DONUT_SUBMISSION_MODERATION="false"

# --- Netlify Blobs (video storage) ---
# Only needed if you are keeping video uploads in Netlify Blobs.
# Found in Netlify dashboard → Site → General → Site Details
NETLIFY_SITE_ID=
NETLIFY_API_TOKEN=

# --- Old direct-PostgreSQL URL (deprecated, kept for rollback) ---
# DATABASE_URL=postgresql://...
